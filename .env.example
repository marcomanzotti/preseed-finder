# Copia questo file in ".env" e inserisci le tue chiavi.
# ".env" e' escluso da git (.gitignore), quindi le chiavi restano locali.

# LLM enrichment: scegli il provider (default=gemini, più economico)
# Opzioni: gemini, anthropic
LLM_PROVIDER=gemini

# Chiave API Gemini (gratuito, free tier disponibile)
# https://ai.google.dev/
GEMINI_API_KEY=

# Chiave API Anthropic (usato solo se LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Hunter.io email enrichment (free tier: 25/mese)
HUNTER_API_KEY=

# Product Hunt API
PRODUCTHUNT_TOKEN=
