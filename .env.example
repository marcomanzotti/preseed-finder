# Copia questo file in ".env" e inserisci le tue chiavi.
# ".env" e' escluso da git (.gitignore), quindi le chiavi restano locali.
#
# LLM enrichment (stage/sector/founder, legge il sito reale di ogni startup —
# l'email NON la indovina l'LLM, la trova email_finder leggendo il sito vero):
# inserisci UNA delle due chiavi sotto. Se inserisci solo
# GEMINI_API_KEY, l'app usa Gemini; se inserisci solo ANTHROPIC_API_KEY, usa
# Claude. Se le inserisci entrambe, usa Gemini (piu' economico) a meno che tu
# non imposti esplicitamente LLM_PROVIDER=anthropic qui sotto.

# Gemini (Google) — modello default: gemini-2.0-flash-lite, il piu' economico.
# Chiave gratuita su https://ai.google.dev/
GEMINI_API_KEY=

# Claude (Anthropic) — modello default: claude-haiku-4-5.
ANTHROPIC_API_KEY=

# Forza il provider invece di farlo dedurre dalle chiavi sopra (opzionale).
# Valori: gemini | anthropic
# LLM_PROVIDER=

# Hunter.io email enrichment (free tier: 25/mese)
HUNTER_API_KEY=

# Product Hunt API
PRODUCTHUNT_TOKEN=

# Crunchbase API (OPT-IN, a pagamento): se presente, abilita la fonte
# "crunchbase". Senza, la fonte si auto-salta. Doc: data.crunchbase.com
CRUNCHBASE_API_KEY=

# Dealroom API (OPT-IN, a pagamento): predisposta in config ma fonte non ancora
# implementata (API enterprise). Lasciare vuoto.
DEALROOM_API_KEY=
